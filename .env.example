# ==========================
# APP CONFIG
# ==========================
APP_NAME=plantera
NODE_ENV=development
APP_DEBUG=true
APP_KEY=your_app_key
APP_URL=http://localhost:8000
PORT=8000
APP_LOCALE=en
ENABLE_SECURITY_HEADERS=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_METHODS=GET,POST,PATCH,PUT,DELETE
ALLOWED_HEADERS=Content-Type,Authorization

# ==========================
# DATABASE CONFIG
# ==========================
DATABASE_DRIVER=PRISMA
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/depiplant
DB_CONNECTION=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=depiplant
DB_USER=postgres
DB_PASSWORD=postgres

# ==========================
# REDIS CONFIG
# ==========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================
# QUEUE CONFIG
# ==========================
QUEUE_DRIVER=BULLMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE_NAME=default_queue

# ==========================
# MAIL CONFIG
# ==========================
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_TIMEOUT=5000
MAIL_ENCRYPTION=tls
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME="Plantera"
MAIL_FROM_EMAIL="no-reply@plantera.app"

# ==========================
# LOGGING CONFIG
# ==========================
LOG_LEVEL=info
LOG_FORMAT=text
LOG_DIR=logs
LOG_FILE_PATH=logs/app.log

# ==========================
# FILESYSTEM / STORAGE CONFIG
# ==========================
FILE_SYSTEM_DISK=LOCAL
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================
# AUTH CONFIG
# ==========================
JWT_SECRET=plantera-jwt-secret-dev
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
OTP_CODE_MIN=100000
OTP_CODE_MAX=999999
OTP_TTL_MINUTES=5
RESET_TOKEN_TTL_MINUTES=5

# ==========================
# FRONTEND CONFIG
# ==========================
FRONTEND_URL=http://localhost:3000

# ==========================
# PLANT ANALYZER CONFIG
# ==========================
ANALYZER_URL=http://localhost:5000/v1
