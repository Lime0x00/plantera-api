# =============================================================================
# Plantera Backend - Environment Configuration
# Copy this file to .env and fill in your values.
# For Docker: values use service names (db, redis, rabbitmq, mailhog) as hosts.
# For local dev outside Docker: replace with localhost / 127.0.0.1.
# =============================================================================

# ---- App ----
APP_NAME=plantera-backend
APP_DEBUG=true
APP_KEY=<your-app-key>
APP_URL=http://localhost:8000
PORT=8000

# CORS — add your frontend URL(s)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- Database ----
DATABASE_URL=postgresql://postgres:postgres@db:5432/plantera
DB_CONNECTION=postgresql
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=plantera

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# ---- Queue (RabbitMQ) ----
QUEUE_DRIVER=BULLMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ---- Mail ----
# Use "none" for MailHog (no TLS on port 1025),
# or "tls"/"ssl" for real SMTP servers.
MAIL_DRIVER=nodemailer
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_ENCRYPTION=none
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=Plantera
MAIL_FROM_EMAIL=no-reply@plantera.local

# ---- Auth ----
JWT_SECRET=<your-jwt-secret>
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# ---- Storage ----
FILE_SYSTEM_DISK=LOCAL
UPLOAD_DIR=/app/public/uploads

# ---- Frontend ----
FRONTEND_URL=http://localhost:3001

# ---- Plant Analyzer (ML) ----
ANALYZER_URL=http://plant-analyzer:5000/v1

# ---- Docker Control ----
# Set to "true" to skip DB initialization in worker (backend only)
DISABLE_DB_INIT=false