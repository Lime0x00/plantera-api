# =============================================================================
# Plantera Backend - Environment Configuration
# Copy this file to .env and fill in your values.
# For Docker: values use service names (db, redis, rabbitmq, mailhog) as hosts.
# For local dev outside Docker: replace with localhost / 127.0.0.1.
# =============================================================================

# ---- App ----
APP_NAME=plantera-backend
APP_DEBUG=true
APP_KEY=<your-app-key>
APP_URL=http://localhost:8000
PORT=8000

# CORS — add your frontend URL(s)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- Database ----
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<dbname>
DB_HOST=<host>
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=<password>
DB_NAME=plantera

# ---- Redis ----
REDIS_HOST=<host>
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://<host>:6379

# ---- Queue (RabbitMQ) ----
QUEUE_DRIVER=BULLMQ
RABBITMQ_HOST=<host>
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ---- Mail ----
# Use "none" for MailHog (no TLS on port 1025),
# or "tls"/"ssl" for real SMTP servers.
MAIL_DRIVER=nodemailer
MAIL_HOST=<smtp-host>
MAIL_PORT=1025
MAIL_ENCRYPTION=none
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=Plantera
MAIL_FROM_EMAIL=no-reply@plantera.local

# ---- Auth ----
JWT_SECRET=<your-jwt-secret>
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# ---- Storage ----
FILE_SYSTEM_DISK=LOCAL
UPLOAD_DIR=/app/public/uploads

# ---- Frontend ----
FRONTEND_URL=http://localhost:3001

# ---- Plant Analyzer (ML) ----
ANALYZER_URL=http://<host>:5000/v1
