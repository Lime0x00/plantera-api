{
  "name": "depi-backend",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsup",
    "prod": "npm run build && doppler run -p backend -c prd -- NODE_ENV=production node dist/server.js",
    "stag": "npm run build && doppler run -p backend -c stg -- NODE_ENV=staging node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:build": "tsup --watch",
    "dev:run": "NODE_ENV=development nodemon --ext ts --exec 'npx tsx' src/server.ts",
    "dev:doppler": "doppler run -p backend -c dev -- npm run dev:run",
    "dev:local": "dotenv -e .env.dev -- npm run dev:run",
    "dev:worker:run": "NODE_ENV=development nodemon --ext ts --exec 'npx tsx' src/worker.ts",
    "dev:worker:doppler": "doppler run -p backend -c dev -- npm run dev:worker:run",
    "dev:worker:local": "dotenv -e .env.dev -- npm run dev:worker:run",
    "dev:worker": "if command -v doppler >/dev/null 2>&1 && doppler configs >/dev/null 2>&1; then npm run dev:worker:doppler; else npm run dev:worker:local; fi",
    "dev": "concurrently --prefix none \"npm run dev:build\" \"if command -v doppler >/dev/null 2>&1 && doppler configs >/dev/null 2>&1; then npm run dev:doppler; else npm run dev:local; fi\"",
    "start:worker": "NODE_ENV=production node dist/worker.js",
    "plop": "./node_modules/plop/bin/plop.js",
    "migrate": "npx prisma migrate deploy && npx prisma generate",
    "seed": "npx tsx database/seeders/main.seeder.ts",
    "server": "npx tsx src/server.ts",
    "worker": "npx tsx src/worker.ts",
    "db:seed": "npm run seed",
    "docs:build": "redocly bundle src/openapi/v1.json --output dist/docs/openapi.json",
    "docs:serve": "http-server ./dist/docs --port 8080 --cors",
    "prebuild": "npm run openapi:generate",
    "openapi:generate": "npx openapi-typescript src/openapi/v1.json -o src/common/types/generated/openapi.types.ts && node scripts/generate-api-messages.js",
    "db:migrate:doppler": "doppler run -p backend -c dev -- npx prisma migrate dev && doppler run -p backend -c dev -- npx prisma generate",
    "db:migrate:local": "dotenv -e .env.dev -- npx prisma migrate dev && dotenv -e .env.dev -- npx prisma generate",
    "db:migrate": "if command -v doppler >/dev/null 2>&1 && doppler configs >/dev/null 2>&1; then npm run db:migrate:doppler; else npm run db:migrate:local; fi",
    "db:deploy:prod": "doppler run -p backend -c prd -- npx prisma migrate deploy && doppler run -p backend -c prd -- npx prisma generate",
    "db:deploy:stag": "doppler run -p backend -c stg -- npx prisma migrate deploy && doppler run -p backend -c stg -- npx prisma generate"
  },
  "overrides": {
    "@hono/node-server": ">=1.19.13"
  },
  "imports": {
    "#app/*": "./src/*",
    "#config": "./src/config/index.ts",
    "#config/*": "./src/config/*",
    "#features/*": "./src/features/*",
    "#infrastructure/*": "./src/infrastructure/*",
    "#framework/*": "./src/framework/*",
    "#common/types/generated/prisma": "./src/common/types/generated/prisma/client.ts",
    "#common/*": "./src/common/*",
    "#routes": "./src/routes/index.ts",
    "#routes/*": "./src/routes/*",
    "#database/*": "./database/*"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "amqplib": "^2.0.1",
    "awilix": "^13.0.5",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nodemailer": "^8.0.11",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@faker-js/faker": "^10.5.0",
    "@redocly/cli": "^2.35.1",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.4",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "http-server": "^14.1.1",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "openapi-typescript": "^7.13.0",
    "plop": "^4.0.5",
    "prettier": "^3.8.5",
    "prisma": "^7.8.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  }
}
