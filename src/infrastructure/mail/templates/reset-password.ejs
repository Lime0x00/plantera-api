<% const msg = t('resetPassword') %>
<%- include('layout', { content: `
  <h2 style="margin: 0 0 16px; color: #111827; font-size: 20px; font-weight: 600;">${msg.subject}</h2>
  <p style="margin: 0 0 8px; color: #4b5563;">${msg.greeting} <strong style="color: #111827;">${firstName}</strong>,</p>
  <p style="margin: 0 0 24px; color: #4b5563;">${msg.codeLabel}</p>
  <div style="font-size: 36px; font-weight: 700; text-align: center; padding: 20px; background: #f9fafb; border-radius: 12px; letter-spacing: 10px; margin: 0 0 24px; color: #059669; border: 1px solid #e5e7eb;">${otp}</div>
  <p style="margin: 0 0 4px; color: #6b7280; font-size: 14px;">${msg.expires}</p>
  <p style="margin: 0 0 24px; color: #9ca3af; font-size: 13px;">${msg.ignore}</p>
  <table role="presentation" style="margin: 0 0 24px;" cellpadding="0" cellspacing="0">
    <tr>
      <td style="background: #059669; border-radius: 9999px; text-align: center;">
        <a href="${frontendUrl}/reset-password" style="display: inline-block; padding: 14px 36px; color: #ffffff; text-decoration: none; font-weight: 500; font-size: 15px; border-radius: 9999px;">${msg.cta}</a>
      </td>
    </tr>
  </table>
  <hr style="border: none; border-top: 1px solid #f3f4f6; margin: 24px 0;">
  <p style="margin: 0; color: #6b7280; font-size: 14px;">- ${msg.footer}</p>
` }) %>
