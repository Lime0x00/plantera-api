<% const msg = t('welcome') %>
<%- include('layout', { content: `
  <h2 style="margin: 0 0 16px; color: #111827; font-size: 20px; font-weight: 600;">${msg.subject}</h2>
  <p style="margin: 0 0 12px; color: #4b5563;">${msg.greeting} <strong style="color: #111827;">${firstName}</strong>,</p>
  <p style="margin: 0 0 24px; color: #4b5563; line-height: 1.7;">${msg.body}</p>
  <table role="presentation" style="margin: 0 0 24px;" cellpadding="0" cellspacing="0">
    <tr>
      <td style="background: #059669; border-radius: 9999px; text-align: center;">
        <a href="${frontendUrl}/garden" style="display: inline-block; padding: 14px 36px; color: #ffffff; text-decoration: none; font-weight: 500; font-size: 15px; border-radius: 9999px;">${msg.cta}</a>
      </td>
    </tr>
  </table>
  <p style="margin: 0; color: #6b7280; font-size: 14px;">${msg.footer}</p>
` }) %>
