generator client {
  provider   = "prisma-client-js"
  output     = "../src/common/types/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum OtpChannel {
  email
  sms
}

enum DiagnosticType {
  classify
  diagnose
}

enum DiagnosticStatusEnum {
  pending
  processing
  completed
  failed
}

enum UserRole {
  user
  admin
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  firstName           String
  lastName            String
  userName            String    @unique
  password            String
  timezone            String?   @default("UTC")
  storageDisk         String?
  storagePath         String?
  pushToken           String?
  pushPlatform        String?   @default("expo")
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  role                UserRole  @default(user)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  myPlants                MyPlant[]
  notificationPreferences NotificationPreferences?
  diagnosticRecords       DiagnosticRecord[]
  careLogs                CareLog[]
  notifications           Notification[]
  refreshTokens           RefreshToken[]
  articles                Article[]
  posts                   Post[]
  comments                Comment[]
  likes                   Like[]
}

model Plant {
  id                   Int       @id @default(autoincrement())
  classifierName       String    @unique
  commonName           String
  scientificName       String?
  family               String?
  about                String?
  temperature          String?
  light                String?
  water                String?
  whereToGrow          String?
  toxicity             String?
  howToGrow            String?
  category             String?
  kingdom              String?
  order_               String?
  imageUrl             String?
  wateringFrequency    Int?
  fertilizingFrequency Int?
  careInstructions     Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  myPlants          MyPlant[]
  diagnosticRecords DiagnosticRecord[]
  notifications     Notification[]
}

model MyPlant {
  id                   Int       @id @default(autoincrement())
  userId               Int
  plantId              Int
  wateringFrequency    Int?
  fertilizingFrequency Int?
  lastWatered          DateTime?
  lastFertilized       DateTime?
  nextWatering         DateTime?
  nextFertilizing      DateTime?
  storageDisk          String?
  storagePath          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  user              User               @relation(fields: [userId], references: [id])
  plant             Plant              @relation(fields: [plantId], references: [id])
  diagnosticRecords DiagnosticRecord[]
  careLogs          CareLog[]
}

model NotificationPreferences {
  id                   Int       @id @default(autoincrement())
  userId               Int       @unique
  pushEnabled          Boolean   @default(true)
  wateringReminders    Boolean   @default(true)
  fertilizingReminders Boolean   @default(true)
  emailNotifications   Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  user User @relation(fields: [userId], references: [id])
}

model Disease {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  otherNames  Json?
  type        String?
  causes      String?
  symptoms    String?
  treatment   Json?
  description String?
  imageUrl    String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Otp {
  id        Int        @id @default(autoincrement())
  email     String
  code      String
  channel   OtpChannel @default(email)
  type      String     @default("password_reset")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())
  deletedAt DateTime?

  @@index([email, code, type])
}

model DiagnosticRecord {
  id          Int                  @id @default(autoincrement())
  userId      Int
  plantId     Int?
  myPlantId   Int?
  type        DiagnosticType
  status      DiagnosticStatusEnum @default(pending)
  storageDisk String?
  storagePath String?
  result      Json?
  error       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?

  user    User     @relation(fields: [userId], references: [id])
  plant   Plant?   @relation(fields: [plantId], references: [id])
  myPlant MyPlant? @relation(fields: [myPlantId], references: [id])
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Notification {
  id            Int       @id @default(autoincrement())
  userId        Int
  plantId       Int?
  type          String
  title         String
  body          String
  isRead        Boolean   @default(false)
  scheduledTime DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  user  User   @relation(fields: [userId], references: [id])
  plant Plant? @relation(fields: [plantId], references: [id])

  @@index([userId, isRead])
}

model CareLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  myPlantId Int
  type      String // "watering" | "fertilizing"
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  myPlant MyPlant @relation(fields: [myPlantId], references: [id])

  @@index([userId, myPlantId])
  @@index([userId, createdAt])
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  excerpt     String?
  category    String?
  storageDisk String?
  storagePath String?
  published   Boolean   @default(false)
  authorId    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  author User @relation(fields: [authorId], references: [id])
}

model Post {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  category    String?
  tags        String?
  storageDisk String?
  storagePath String?
  published   Boolean   @default(true)
  authorId    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  author   User      @relation(fields: [authorId], references: [id])
  comments Comment[]
  likes    Like[]

  @@index([authorId])
  @@index([category])
  @@index([published])
}

model Comment {
  id        Int       @id @default(autoincrement())
  content   String
  postId    Int
  authorId  Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  post   Post @relation(fields: [postId], references: [id])
  author User @relation(fields: [authorId], references: [id])

  @@index([postId])
  @@index([authorId])
}

model Like {
  id        Int       @id @default(autoincrement())
  postId    Int
  authorId  Int
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  post   Post @relation(fields: [postId], references: [id])
  author User @relation(fields: [authorId], references: [id])

  @@unique([postId, authorId])
  @@index([postId])
  @@index([authorId])
}
